<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🎯 OUT Tournament</title>
<script src="https://unpkg.com/xlsx/dist/xlsx.full.min.js"></script>
<style>
:root {
  --bg: #072b22;
  --panel: #053a2e;
  --border: #0b4f40;
  --text: #e9fff7;
  --green: #17d766;
  --red: #ff3b3b;
  --neon: #39ff14;
  --gold: #d6a62b;
  --locked: #021a13;
  --card: #063326;
  --orange: #ff8c00;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Segoe UI', system-ui, sans-serif;
  font-weight: 500;
  min-height: 100vh;
}
h1 {
  padding: 10px 16px;
  background: var(--panel);
  border-bottom: 2px solid var(--border);
  font-size: 19px;
  color: var(--gold);
  letter-spacing: 2px;
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 12px;
}
#setup-panel {
  display: flex;
  gap: 14px;
  padding: 12px 16px;
  background: var(--panel);
  border-bottom: 2px solid var(--border);
  flex-wrap: wrap;
  align-items: flex-start;
}
#team-input-col { display: flex; flex-direction: column; gap: 7px; flex: 1; min-width: 280px; }
#team-names {
  width: 100%; height: 90px;
  background: var(--bg); color: var(--text);
  border: 1px solid var(--border); border-radius: 7px;
  padding: 7px; font-family: inherit; font-size: 12px; resize: vertical;
}
.input-row { display: flex; gap: 7px; align-items: center; flex-wrap: wrap; }
.input-row label { font-size: 11px; color: #7ec9a9; white-space: nowrap; }
select, input[type="date"], input[type="text"], input[type="number"] {
  background: var(--bg); color: var(--text);
  border: 1px solid var(--border); border-radius: 5px;
  padding: 3px 7px; font-family: inherit; font-size: 12px;
}
select:focus, input:focus { outline: none; border-color: var(--green); }
/* Hide number spinners globally */
input[type="number"]::-webkit-outer-spin-button,
input[type="number"]::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
input[type="number"] { -moz-appearance: textfield; }
.btn {
  padding: 5px 12px; border: none; border-radius: 5px;
  cursor: pointer; font-family: inherit; font-size: 12px;
  font-weight: 600; transition: all 0.15s; white-space: nowrap;
}
.btn-primary { background: var(--green); color: #000; }
.btn-primary:hover { background: #12b554; }
.btn-secondary { background: var(--border); color: var(--text); }
.btn-secondary:hover { background: #0d6655; }
.btn-gold { background: var(--gold); color: #000; }
.btn-gold:hover { background: #b8891f; }
.btn-danger { background: #6b1111; color: var(--text); }
.btn-danger:hover { background: #9b1a1a; }
.btn-orange { background: #7a4200; color: var(--text); border: 1px solid var(--orange); }
.btn-orange:hover { background: var(--orange); color: #000; }
/* Board Status */
#board-col { display: flex; flex-direction: column; gap: 7px; }
#board-col h3 { font-size: 11px; color: #7ec9a9; text-transform: uppercase; letter-spacing: 0.5px; }
#board-boxes { display: flex; gap: 5px; flex-wrap: wrap; }
.board-box {
  width: 30px; height: 30px; background: var(--bg);
  border: 2px solid var(--border); border-radius: 5px;
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 700; transition: all 0.3s;
}
.board-box.active {
  background: var(--neon); border-color: var(--neon); color: #000;
  box-shadow: 0 0 8px var(--neon);
}
/* Bracket */
#bracket-container { padding: 12px; overflow-x: auto; }
.bracket-label {
  font-size: 12px; font-weight: 700; color: var(--gold);
  text-transform: uppercase; letter-spacing: 1px;
  padding: 5px 0; margin-bottom: 8px;
  border-bottom: 1px solid var(--border);
}
.bracket-section { display: flex; gap: 5px; margin-bottom: 20px; align-items: flex-start; }
.bracket-column { display: flex; flex-direction: column; min-width: 228px; gap: 0; }
.col-header {
  text-align: center; font-size: 10px; font-weight: 700; color: #7ec9a9;
  text-transform: uppercase; padding: 3px;
  background: var(--panel); border-radius: 4px; margin-bottom: 5px;
  letter-spacing: 0.5px;
}
.col-matches { display: flex; flex-direction: column; gap: 6px; }

/* ── COMPACT MATCH CARD ── */
.match-card {
  background: var(--card); border: 1px solid var(--border);
  border-radius: 10px; padding: 7px 8px 6px;
  box-shadow: 0 2px 6px rgba(0,0,0,0.3); transition: border-color 0.2s;
  min-width: 216px;
}
.match-card:hover:not(.locked) { border-color: #1a7a5a; }
.match-card.locked { background: var(--locked); border-color: #082518; }
.match-card.in-progress {
  border-color: var(--neon);
  box-shadow: 0 0 10px rgba(57,255,20,0.22);
  animation: pulseCard 2s infinite;
}
.match-card.highlighted { border-color: var(--gold) !important; box-shadow: 0 0 14px rgba(214,166,43,0.5) !important; }
.match-card.gf-card { border: 2px solid var(--gold); box-shadow: 0 0 18px rgba(214,166,43,0.3); }
@keyframes pulseCard { 0%,100%{box-shadow:0 0 6px rgba(57,255,20,0.12)} 50%{box-shadow:0 0 16px rgba(57,255,20,0.45)} }

.match-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2px; }
.match-id { font-size: 10px; font-weight: 700; color: var(--gold); }
.match-rname { font-size: 9px; color: #7ec9a9; }
.match-src { font-size: 9px; color: #4a9a7a; margin-bottom: 5px; }

/* Team rows — compact */
.team-row {
  display: flex; align-items: center; gap: 4px;
  padding: 3px 4px; border-radius: 5px;
  margin-bottom: 2px; background: rgba(255,255,255,0.02);
}
.team-row.wr { background: rgba(23,215,102,0.1); }
.team-row.lr { background: rgba(255,59,59,0.07); }
.team-icon { font-size: 11px; width: 14px; flex-shrink: 0; }
.tname { flex: 1; font-size: 13px; font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.tname.w { color: var(--green); font-weight: 700; }
.tname.l { color: var(--red); text-decoration: line-through; }
.tname.hover-opponent { background: rgba(255,140,0,0.25); border-radius: 3px; outline: 2px solid var(--orange); }
.score-inp { width: 34px; text-align: center; padding: 2px 3px; font-size: 12px; }
.pick-btn {
  padding: 2px 7px; background: #0b4f40; color: var(--text);
  border: none; border-radius: 4px; cursor: pointer;
  font-size: 10px; font-weight: 700; flex-shrink: 0;
}
.pick-btn:hover { background: var(--green); color: #000; }
.pick-btn:disabled { opacity: 0.25; cursor: default; }

/* Simplified match footer */
.match-foot {
  display: flex; align-items: center; gap: 6px;
  margin-top: 4px; padding-top: 4px;
  border-top: 1px solid var(--border);
}
.board-inp { width: 44px; }
.lbl { font-size: 10px; color: #7ec9a9; }
.undo-btn {
  margin-left: auto;
  background: #2a1515; color: #ff8888;
  border: 1px solid #ff3b3b44; border-radius: 4px;
  padding: 2px 7px; cursor: pointer; font-size: 10px; font-weight: 700;
}
.undo-btn:hover { background: var(--red); color: #fff; }

/* ── SMALL MODE (30+ teams: ~30% smaller cards) ── */
#bracket-container.small-mode .bracket-column { min-width: 168px; }
#bracket-container.small-mode .match-card { padding: 5px 5px 4px; min-width: 156px; border-radius: 8px; }
#bracket-container.small-mode .match-id { font-size: 8px; }
#bracket-container.small-mode .match-rname { font-size: 7px; }
#bracket-container.small-mode .match-src { font-size: 7px; margin-bottom: 3px; }
#bracket-container.small-mode .tname { font-size: 9px; }
#bracket-container.small-mode .team-icon { font-size: 9px; width: 11px; }
#bracket-container.small-mode .score-inp { width: 25px; font-size: 9px; padding: 1px 2px; }
#bracket-container.small-mode .pick-btn { font-size: 7px; padding: 1px 4px; }
#bracket-container.small-mode .match-foot { gap: 4px; margin-top: 2px; padding-top: 2px; }
#bracket-container.small-mode .board-inp { width: 30px; font-size: 8px; }
#bracket-container.small-mode .lbl { font-size: 7px; }
#bracket-container.small-mode .undo-btn { font-size: 7px; padding: 1px 4px; }
#bracket-container.small-mode .col-header { font-size: 8px; }
#bracket-container.small-mode .col-matches { gap: 4px; }

/* GF Section */
#gf-section { display: flex; flex-direction: column; align-items: center; padding: 0 16px 16px; }
#gf-match { min-width: 260px; max-width: 340px; }

/* Standings */
#standings-section { padding: 12px 16px; border-top: 2px solid var(--border); }
#standings-section h2 { font-size: 15px; color: var(--gold); margin-bottom: 8px; }
#standings-table { width: 100%; border-collapse: collapse; }
#standings-table th, #standings-table td { padding: 6px 9px; text-align: left; border-bottom: 1px solid var(--border); font-size: 12px; }
#standings-table th { background: var(--panel); color: #7ec9a9; font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; }
#standings-table tr:hover td { background: rgba(255,255,255,0.025); }
.team-link { cursor: pointer; text-decoration: underline dotted; color: var(--text); }
.team-link:hover { color: var(--green); }

/* History */
#history-section { padding: 12px 16px; border-top: 2px solid var(--border); }
#history-section h2 { font-size: 15px; color: var(--gold); margin-bottom: 8px; display: flex; gap: 10px; align-items: center; }
#history-table { width: 100%; border-collapse: collapse; font-size: 11px; }
#history-table th, #history-table td { padding: 5px 9px; text-align: left; border-bottom: 1px solid var(--border); }
#history-table th { background: var(--panel); color: #7ec9a9; font-size: 10px; text-transform: uppercase; }

/* Overlay */
#active-overlay {
  position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
  background: rgba(2,8,5,0.97); z-index: 1000;
  display: flex; flex-direction: column;
}
.ov-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 11px 18px; border-bottom: 2px solid var(--border);
  background: var(--panel); flex-shrink: 0;
}
.ov-title { font-size: 18px; font-weight: 700; color: var(--gold); letter-spacing: 2px; text-transform: uppercase; }
.ov-body { display: flex; flex: 1; overflow: hidden; }
.ov-left { width: 40%; border-right: 2px solid var(--border); overflow-y: auto; padding: 10px; display: flex; flex-direction: column; gap: 7px; }
.ov-right { flex: 1; overflow: auto; background: #020c06; position: relative; }
.active-row {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 12px; background: var(--panel);
  border: 1px solid var(--border); border-radius: 9px;
  cursor: pointer; transition: border-color 0.15s;
}
.active-row:hover { border-color: var(--green); }
.active-row.winner-selected { border-color: var(--neon) !important; background: rgba(57,255,20,0.06) !important; box-shadow: 0 0 10px rgba(57,255,20,0.2); }
.board-badge {
  width: 46px; height: 46px; background: #072b07;
  border: 2px solid var(--neon); border-radius: 7px;
  display: flex; align-items: center; justify-content: center;
  font-size: 20px; font-weight: 800; color: var(--neon);
  flex-shrink: 0; box-shadow: 0 0 9px rgba(57,255,20,0.3);
}
.board-badge-empty { border-color: var(--border); color: #4a9a7a; box-shadow: none; }
.active-teams { flex: 1; }
.active-teams-main { font-size: 16px; font-weight: 700; line-height: 1.2; }
.active-teams-info { font-size: 10px; color: #7ec9a9; margin-top: 2px; }
.no-active { text-align: center; color: #4a7a5a; padding: 36px 18px; font-size: 15px; }

/* Overlay pick buttons */
.ov-pick-btns { display: flex; gap: 5px; flex-direction: column; flex-shrink: 0; }
.ov-pick-btn {
  padding: 4px 9px; border: 1px solid var(--border);
  border-radius: 5px; cursor: pointer; font-size: 11px; font-weight: 700;
  background: #0b4f40; color: var(--text); white-space: nowrap;
  transition: all 0.15s;
}
.ov-pick-btn:hover { background: var(--neon); color: #000; border-color: var(--neon); }
.ov-pick-btn.picked-a, .ov-pick-btn.picked-b { background: rgba(23,215,102,0.15); border-color: var(--green); color: var(--green); }
.ov-pick-btn:disabled { opacity: 0.35; cursor: default; }

/* Stats Popup */
.popup-bg {
  position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
  background: rgba(0,0,0,0.65); z-index: 1999;
}
#stats-popup {
  position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%);
  background: var(--panel); border: 2px solid var(--gold);
  border-radius: 12px; padding: 18px; z-index: 2000;
  min-width: 300px; box-shadow: 0 10px 40px rgba(0,0,0,0.8);
}
#stats-popup h3 { color: var(--gold); margin-bottom: 12px; font-size: 14px; }
.sf { display: flex; flex-direction: column; gap: 3px; margin-bottom: 10px; }
.sf label { font-size: 11px; color: #7ec9a9; }
.sf input { width: 100%; }

/* Bracket Full View Overlay */
#bracket-overlay {
  position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
  background: rgba(2,8,5,0.98); z-index: 1000;
  display: flex; flex-direction: column;
}
#bracket-overlay .ov-header { padding: 11px 18px; }
#bracket-viz-wrap { flex: 1; overflow: auto; background: #020c06; padding: 10px; }

/* SVG Viz */
#viz-svg text, #bov-svg text { font-family: 'Segoe UI', system-ui, sans-serif; }
</style>
</head>
<body>
<h1>🎯 OUT Tournament</h1>
<div id="setup-panel">
  <div id="team-input-col">
    <div class="input-row">
      <label>Takım Sayısı:</label>
      <select id="team-count-select" onchange="onTeamCountChange()"></select>
      <label>Best of:</label>
      <select id="best-of">
        <option value="1">Bo1</option>
        <option value="3" selected>Bo3</option>
        <option value="5">Bo5</option>
      </select>
      <label>Tarih:</label>
      <input type="date" id="tournament-date">
    </div>
    <textarea id="team-names" placeholder="Takım adlarını yapıştırın (her satıra bir takım)..."></textarea>
    <div class="input-row">
      <button class="btn btn-primary" onclick="applyTournament()">Uygula</button>
      <button class="btn btn-secondary" onclick="shuffleTeams()">Karıştır</button>
      <button class="btn btn-danger" onclick="resetTournament()">Sıfırla</button>
      <button class="btn btn-gold" onclick="openOverlay()">OYNANAN MAÇLAR</button>
      <button class="btn btn-orange" onclick="openBracketOverlay()">📊 BRACKET</button>
    </div>
  </div>
  <div id="board-col">
    <h3>Board NO</h3>
    <div id="board-boxes"></div>
  </div>
</div>
<div id="bracket-container">
  <div class="bracket-label">★ Winners Bracket</div>
  <div id="wb-rounds" class="bracket-section"></div>
  <div class="bracket-label">★ Losers Bracket</div>
  <div id="lb-rounds" class="bracket-section"></div>
  <div id="gf-section">
    <div class="bracket-label" style="text-align:center">🏆 Grand Final</div>
    <div id="gf-match"></div>
  </div>
</div>
<div id="standings-section">
  <h2>Sıralama</h2>
  <table id="standings-table">
    <thead><tr>
      <th>Sıra</th><th>Takım</th><th>Puan</th>
      <th>Ort Dart/Leg</th><th>Oynadı</th><th>180s</th><th>High Out</th>
    </tr></thead>
    <tbody id="standings-body"></tbody>
  </table>
</div>
<div id="history-section">
  <h2>Maç Geçmişi <button class="btn btn-secondary" onclick="exportHistory()">Excel'e Aktar</button></h2>
  <table id="history-table">
    <thead><tr>
      <th>#</th><th>Round</th><th>Takım A</th><th>Skor A</th>
      <th>Skor B</th><th>Takım B</th><th>Kazanan</th><th>Board NO</th>
    </tr></thead>
    <tbody id="history-body"></tbody>
  </table>
</div>

<!-- Active Matches Overlay -->
<div id="active-overlay" style="display:none">
  <div class="ov-header">
    <div class="ov-title">Oynanan Maçlar</div>
    <button class="btn btn-secondary" onclick="closeOverlay()" style="font-size:15px;padding:5px 11px">✕ Kapat</button>
  </div>
  <div class="ov-body">
    <div class="ov-left" id="ov-active-list"></div>
    <div class="ov-right">
      <div style="padding:7px 10px;font-size:10px;color:#4a7a5a;border-bottom:1px solid var(--border)">Bracket Görünümü — Maça tıklayarak kazanan seçebilirsiniz</div>
      <div id="viz-wrap" style="width:100%;height:calc(100% - 24px);overflow:auto">
        <svg id="viz-svg" xmlns="http://www.w3.org/2000/svg" style="display:block"></svg>
      </div>
    </div>
  </div>
</div>

<!-- Bracket Full View Overlay -->
<div id="bracket-overlay" style="display:none">
  <div class="ov-header">
    <div class="ov-title">📊 Bracket Tree</div>
    <button class="btn btn-secondary" onclick="closeBracketOverlay()" style="font-size:15px;padding:5px 11px">✕ Kapat</button>
  </div>
  <div id="bracket-viz-wrap">
    <svg id="bov-svg" xmlns="http://www.w3.org/2000/svg" style="display:block"></svg>
  </div>
</div>

<!-- Stats Popup -->
<div class="popup-bg" id="popup-bg" style="display:none" onclick="closeStatsPopup()"></div>
<div id="stats-popup" style="display:none">
  <h3 id="sp-title">Takım İstatistikleri</h3>
  <div class="sf"><label>180 Sayısı</label><input type="number" id="sp-180" min="0" placeholder="0"></div>
  <div class="sf"><label>Out Sayıları (virgülle ayırın)</label><input type="text" id="sp-out" placeholder="ör: 170,167,130,116"></div>
  <div class="sf"><label>Yüksek Çıkışlar (virgülle ayırın)</label><input type="text" id="sp-hout" placeholder="ör: 170,167,130"></div>
  <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:10px">
    <button class="btn btn-primary" onclick="saveStatsPopup()">Kaydet</button>
    <button class="btn btn-secondary" onclick="closeStatsPopup()">Kapat</button>
  </div>
</div>

<script>
// ============================================================
// STATE
// ============================================================
const S = {
  teams: [], numTeams: 16, matches: [], bracket: null,
  bestOf: 3, date: '',
  teamStats: {},
  history: [],
  undoStack: [],
  statsTeam: null,
  vizWinner: {}
};

// ============================================================
// BRACKET ENGINE
// ============================================================
function seedOrder(p) {
  if (p <= 1) return [1];
  if (p === 2) return [1, 2];
  const prev = seedOrder(p >> 1);
  const res = [];
  prev.forEach(s => res.push(s, p + 1 - s));
  return res;
}
function nextP2(n) { let p = 1; while (p < n) p <<= 1; return p; }

function buildBracket(numTeams) {
  const P = nextP2(Math.max(numTeams, 4));
  const K = Math.log2(P);
  const seeds = seedOrder(P);
  const matches = [];
  let nid = 1;

  function M(bracket, wr, lr, roundName, sA, sB) {
    const m = {
      id: nid++, bracket, wbRound: wr, lbRound: lr, roundName,
      srcA: sA, srcB: sB,
      teamA: null, teamB: null,
      scoreA: '', scoreB: '',
      board: '', locked: false,
      winner: null, loser: null, winnerSlot: null,
      winTo: null, loseTo: null, winSlot: null, loseSlot: null
    };
    matches.push(m); return m;
  }

  const wbR = {};
  const wbR1 = [];
  for (let i = 0; i < P / 2; i++) {
    const sA = seeds[i * 2], sB = seeds[i * 2 + 1];
    const rn = K === 1 ? 'Winners Final' : 'Winners R1';
    wbR1.push(M('W', 1, null, rn, { type: 'seed', v: sA }, { type: 'seed', v: sB }));
  }
  wbR[1] = wbR1;

  for (let r = 2; r <= K; r++) {
    const prev = wbR[r - 1], curr = [];
    let rn;
    if (r === K) rn = 'Winners Final';
    else if (r === K - 1) rn = 'Winners SF';
    else if (r === K - 2) rn = 'Winners QF';
    else rn = 'Winners R' + r;
    for (let i = 0; i < prev.length; i += 2) {
      const m = M('W', r, null, rn,
        { type: 'win', mid: prev[i].id },
        { type: 'win', mid: prev[i + 1].id });
      prev[i].winTo = m.id; prev[i].winSlot = 'A';
      prev[i + 1].winTo = m.id; prev[i + 1].winSlot = 'B';
      curr.push(m);
    }
    wbR[r] = curr;
  }
  const wbFinal = wbR[K][0];

  const lbR = {};
  let lbN = 0;
  let prevLB = null;

  if (P >= 4) {
    lbN++;
    const lb1 = [];
    for (let i = 0; i < wbR1.length; i += 2) {
      const m = M('L', null, lbN, 'Losers R' + lbN,
        { type: 'lose', mid: wbR1[i].id },
        { type: 'lose', mid: wbR1[i + 1].id });
      wbR1[i].loseTo = m.id; wbR1[i].loseSlot = 'A';
      wbR1[i + 1].loseTo = m.id; wbR1[i + 1].loseSlot = 'B';
      lb1.push(m);
    }
    lbR[lbN] = lb1;
    prevLB = lb1;

    for (let wri = 2; wri <= K; wri++) {
      const wbLosers = [...wbR[wri]].reverse();
      const isLast = wri === K;
      lbN++;
      const intName = isLast ? 'Losers Final' : 'Losers R' + lbN;
      const intM = [];
      for (let i = 0; i < prevLB.length; i++) {
        const wbSrc = wbLosers[i % wbLosers.length];
        const m = M('L', null, lbN, intName,
          { type: 'win', mid: prevLB[i].id },
          { type: 'lose', mid: wbSrc.id });
        prevLB[i].winTo = m.id; prevLB[i].winSlot = 'A';
        if (!wbSrc.loseTo) { wbSrc.loseTo = m.id; wbSrc.loseSlot = 'B'; }
        intM.push(m);
      }
      lbR[lbN] = intM;
      prevLB = intM;
      if (!isLast && intM.length > 1) {
        lbN++;
        const consM = [];
        for (let i = 0; i < intM.length; i += 2) {
          const m = M('L', null, lbN, 'Losers R' + lbN,
            { type: 'win', mid: intM[i].id },
            { type: 'win', mid: intM[i + 1].id });
          intM[i].winTo = m.id; intM[i].winSlot = 'A';
          intM[i + 1].winTo = m.id; intM[i + 1].winSlot = 'B';
          consM.push(m);
        }
        lbR[lbN] = consM;
        prevLB = consM;
      }
    }
  }
  const lbFinal = prevLB ? prevLB[0] : null;

  const gf = M('GF', null, null, 'Grand Final',
    { type: 'win', mid: wbFinal.id },
    lbFinal ? { type: 'win', mid: lbFinal.id } : { type: 'seed', v: null });
  wbFinal.winTo = gf.id; wbFinal.winSlot = 'A';
  if (lbFinal) { lbFinal.winTo = gf.id; lbFinal.winSlot = 'B'; }

  return { matches, wbR, lbR, lbN, gf, P, K };
}

// ============================================================
// HELPERS
// ============================================================
function getM(id) { return S.matches.find(m => m.id === id); }
function isBye(name) { return !name || name === 'BYE'; }

// Get the board value from DOM or state (persisting correctly)
function getBoardValue(mid) {
  const bEl = document.getElementById('brd-' + mid);
  return bEl ? bEl.value.trim() : (getM(mid)?.board || '');
}

// Sync DOM board inputs back into state (called before re-render)
function syncBoardsToState() {
  S.matches.forEach(m => {
    if (!m.locked) {
      const bEl = document.getElementById('brd-' + m.id);
      if (bEl) m.board = bEl.value;
    }
  });
}

// ============================================================
// APPLY / INIT
// ============================================================
function applyTournament() {
  const raw = document.getElementById('team-names').value.trim();
  let names = raw ? raw.split('\n').map(n => n.trim()).filter(Boolean) : [];
  const n = parseInt(document.getElementById('team-count-select').value) || 16;
  while (names.length < n) names.push('Team ' + (names.length + 1));
  names = names.slice(0, n);

  S.numTeams = n;
  S.teams = names.map((name, i) => ({ name, seed: i + 1 }));
  S.bestOf = parseInt(document.getElementById('best-of').value);
  S.date = document.getElementById('tournament-date').value;

  const bracket = buildBracket(n);
  S.bracket = bracket;
  S.matches = bracket.matches;

  S.teamStats = {};
  S.teams.forEach(t => {
    S.teamStats[t.name] = { points: 0, legs: 0, avgSum: 0, played: 0, s180: 0, highOuts: [], outNums: [], wbWins: 0, lbWins: 0, gfWin: false };
  });
  S.history = [];
  S.undoStack = [];
  S.vizWinner = {};

  const bc = document.getElementById('bracket-container');
  bc.classList.toggle('small-mode', n >= 30);

  // Seed teams into R1 matches
  S.matches.forEach(m => {
    if (m.bracket === 'W' && m.wbRound === 1) {
      const tA = S.teams.find(t => t.seed === m.srcA?.v);
      const tB = S.teams.find(t => t.seed === m.srcB?.v);
      m.teamA = tA ? tA.name : 'BYE';
      m.teamB = tB ? tB.name : 'BYE';
    }
  });

  resolveByes();
  renderAll();
}

function shuffleTeams() {
  const raw = document.getElementById('team-names').value.trim();
  let names = raw ? raw.split('\n').map(n => n.trim()).filter(Boolean) : [];
  for (let i = names.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [names[i], names[j]] = [names[j], names[i]];
  }
  document.getElementById('team-names').value = names.join('\n');
}

function resetTournament() {
  if (!confirm('Turnuvayı sıfırlamak istediğinize emin misiniz?')) return;
  S.teams = []; S.matches = []; S.bracket = null;
  S.teamStats = {}; S.history = []; S.undoStack = []; S.vizWinner = {};
  document.getElementById('wb-rounds').innerHTML = '';
  document.getElementById('lb-rounds').innerHTML = '';
  document.getElementById('gf-match').innerHTML = '';
  document.getElementById('standings-body').innerHTML = '';
  document.getElementById('history-body').innerHTML = '';
  initBoardBoxes();
}

function onTeamCountChange() {
  // No auto-apply
}

// ============================================================
// MATCH RESOLUTION
// ============================================================
function resolveByes() {
  let changed = true;
  while (changed) {
    changed = false;
    S.matches.forEach(m => {
      if (m.locked) return;
      // Only auto-resolve when slot is explicitly 'BYE', not null (unset)
      if (m.teamA === 'BYE' && m.teamB === 'BYE') {
        resolveMatch(m.id, 'A', true); changed = true;
      } else if (m.teamA === 'BYE' && m.teamB && m.teamB !== 'BYE') {
        resolveMatch(m.id, 'B', true); changed = true;
      } else if (m.teamB === 'BYE' && m.teamA && m.teamA !== 'BYE') {
        resolveMatch(m.id, 'A', true); changed = true;
      }
    });
  }
}

function selectWinner(mid, slot) {
  // Sync all board inputs to state BEFORE resolving
  syncBoardsToState();
  const m = getM(mid);
  if (!m || m.locked) return;
  if (!m.teamA || !m.teamB) { alert('Her iki takım da belirlenmelidir.'); return; }
  if (isBye(m.teamA) || isBye(m.teamB)) { alert('BYE maçı oynatamazsınız.'); return; }
  const sA = parseInt(document.getElementById('sca-' + mid)?.value) || 0;
  const sB = parseInt(document.getElementById('scb-' + mid)?.value) || 0;
  m.scoreA = sA; m.scoreB = sB;
  // board already synced via syncBoardsToState
  resolveMatch(mid, slot, false);
  resolveByes();
  renderAll();
}

// Winner selection from viz overlay
function selectWinnerFromViz(mid, slot) {
  syncBoardsToState();
  const m = getM(mid);
  if (!m || m.locked) return;
  if (!m.teamA || !m.teamB || isBye(m.teamA) || isBye(m.teamB)) return;
  m.scoreA = 0; m.scoreB = 0;
  resolveMatch(mid, slot, false);
  resolveByes();
  delete S.vizWinner[mid];
  renderAll();
  if (document.getElementById('active-overlay').style.display !== 'none') {
    renderOverlay();
    renderViz('viz-svg');
  }
  if (document.getElementById('bracket-overlay').style.display !== 'none') {
    renderViz('bov-svg');
  }
}

function resolveMatch(mid, slot, bye) {
  const m = getM(mid);
  if (!m || m.locked) return;
  const winner = slot === 'A' ? m.teamA : m.teamB;
  const loser = slot === 'A' ? m.teamB : m.teamA;
  m.locked = true;
  m.winner = winner;
  m.loser = loser;
  m.winnerSlot = slot;

  if (!bye) {
    updateStats(m, winner, loser);
    S.history.push({
      n: S.history.length + 1, mid: m.id,
      round: m.roundName, teamA: m.teamA,
      sA: m.scoreA, sB: m.scoreB, teamB: m.teamB,
      winner, board: m.board
    });
    S.undoStack.push({ mid: m.id });
  }

  if (m.winTo) {
    const t = getM(m.winTo);
    if (t && !t.locked) { if (m.winSlot === 'A') t.teamA = winner; else t.teamB = winner; }
  }
  if (m.loseTo) {
    const t = getM(m.loseTo);
    if (t && !t.locked) {
      const val = isBye(loser) ? 'BYE' : loser;
      if (m.loseSlot === 'A') t.teamA = val; else t.teamB = val;
    }
  }
}

function undoMatch(mid) {
  const m = getM(mid);
  if (!m || !m.locked) return;
  const winner = m.winner, loser = m.loser;
  removeStats(m, winner, loser);
  if (m.winTo) {
    const t = getM(m.winTo);
    if (t && !t.locked) { if (m.winSlot === 'A') t.teamA = null; else t.teamB = null; }
  }
  if (m.loseTo) {
    const t = getM(m.loseTo);
    if (t && !t.locked) { if (m.loseSlot === 'A') t.teamA = null; else t.teamB = null; }
  }
  m.locked = false; m.winner = null; m.loser = null; m.winnerSlot = null;
  S.history = S.history.filter(h => h.mid !== mid);
  S.undoStack = S.undoStack.filter(u => u.mid !== mid);
  renderAll();
}

function updateStats(m, winner, loser) {
  const ensure = n => {
    if (n && !isBye(n) && !S.teamStats[n])
      S.teamStats[n] = { points: 0, legs: 0, avgSum: 0, played: 0, s180: 0, highOuts: [], outNums: [], wbWins: 0, lbWins: 0, gfWin: false };
  };
  ensure(winner); ensure(loser);
  if (winner && !isBye(winner)) {
    const s = S.teamStats[winner];
    s.played++;
    if (m.bracket === 'GF') { s.points += 6; s.gfWin = true; }
    else if (m.bracket === 'W') { s.points += 3; s.wbWins++; }
    else { s.points += 1; s.lbWins++; }
  }
  if (loser && !isBye(loser)) {
    const s = S.teamStats[loser];
    s.played++;
  }
}

function removeStats(m, winner, loser) {
  if (winner && !isBye(winner) && S.teamStats[winner]) {
    const s = S.teamStats[winner];
    s.played = Math.max(0, s.played - 1);
    if (m.bracket === 'GF') { s.points = Math.max(0, s.points - 6); s.gfWin = false; }
    else if (m.bracket === 'W') { s.points = Math.max(0, s.points - 3); s.wbWins = Math.max(0, s.wbWins - 1); }
    else { s.points = Math.max(0, s.points - 1); s.lbWins = Math.max(0, s.lbWins - 1); }
  }
  if (loser && !isBye(loser) && S.teamStats[loser]) {
    const s = S.teamStats[loser];
    s.played = Math.max(0, s.played - 1);
  }
}

// ============================================================
// HOVER OPPONENT HIGHLIGHT
// ============================================================
// For a given match card, find the "incoming opponent" team name
function getIncomingOpponent(m, slot) {
  // The opponent for slot A comes from srcB, and vice versa
  const oppSrc = slot === 'A' ? m.srcB : m.srcA;
  if (!oppSrc) return null;
  if (oppSrc.type === 'win') {
    const srcM = getM(oppSrc.mid);
    return srcM ? srcM.winner : null;
  }
  if (oppSrc.type === 'lose') {
    const srcM = getM(oppSrc.mid);
    return srcM ? srcM.loser : null;
  }
  return null;
}

// On hover over a team row, find match where that team will next play
// and highlight their opponent
function onTeamHover(teamName) {
  if (!teamName || teamName === 'BYE') return;
  // Find the next (unlocked) match this team is in
  const nextMatch = S.matches.find(m => !m.locked && (m.teamA === teamName || m.teamB === teamName));
  if (!nextMatch) return;
  const slot = nextMatch.teamA === teamName ? 'A' : 'B';
  const oppSlot = slot === 'A' ? 'B' : 'A';
  const oppName = slot === 'A' ? nextMatch.teamB : nextMatch.teamA;
  if (!oppName || isBye(oppName)) return;
  // Highlight opponent in the current match card
  const oppEl = document.getElementById('tn-' + nextMatch.id + '-' + oppSlot);
  if (oppEl) oppEl.classList.add('hover-opponent');
  // Also highlight opponent in ANY other unlocked match they appear in
  S.matches.forEach(m2 => {
    if (m2.locked || m2.id === nextMatch.id) return;
    if (m2.teamA === oppName) {
      const el = document.getElementById('tn-' + m2.id + '-A');
      if (el) el.classList.add('hover-opponent');
    }
    if (m2.teamB === oppName) {
      const el = document.getElementById('tn-' + m2.id + '-B');
      if (el) el.classList.add('hover-opponent');
    }
  });
}

function onTeamLeave() {
  document.querySelectorAll('.tname.hover-opponent').forEach(el => el.classList.remove('hover-opponent'));
}

// ============================================================
// RENDER
// ============================================================
function renderAll() {
  renderBracket();
  renderStandings();
  renderHistory();
  updateBoardBoxes();
  if (document.getElementById('active-overlay').style.display !== 'none') {
    renderOverlay();
  }
  if (document.getElementById('bracket-overlay').style.display !== 'none') {
    renderViz('bov-svg');
  }
}

function matchCard(m) {
  const locked = m.locked;
  const inProg = !locked && m.teamA && m.teamB && m.board && !isBye(m.teamA) && !isBye(m.teamB);
  const isGF = m.bracket === 'GF';

  const srcLabel = (() => {
    const lA = m.srcA ? (m.srcA.type === 'seed' ? 'Seed ' + m.srcA.v : (m.srcA.type === 'win' ? 'M' + m.srcA.mid + ' W' : 'M' + m.srcA.mid + ' L')) : '?';
    const lB = m.srcB ? (m.srcB.type === 'seed' ? 'Seed ' + m.srcB.v : (m.srcB.type === 'win' ? 'M' + m.srcB.mid + ' W' : 'M' + m.srcB.mid + ' L')) : '?';
    return lA + ' vs ' + lB;
  })();

  const wA = locked && m.winnerSlot === 'A';
  const wB = locked && m.winnerSlot === 'B';

  const cls = `match-card${locked ? ' locked' : ''}${inProg ? ' in-progress' : ''}${isGF ? ' gf-card' : ''}`;

  const dispA = m.teamA ? m.teamA : '<span style="color:#4a7a5a">Bekleniyor</span>';
  const dispB = m.teamB ? m.teamB : '<span style="color:#4a7a5a">Bekleniyor</span>';

  const boardVal = m.board || '';

  return `<div class="${cls}" id="mc-${m.id}" data-mid="${m.id}">
  <div class="match-header">
    <span class="match-id">M${m.id}</span>
    <span class="match-rname">${m.roundName}</span>
  </div>
  <div class="match-src">${srcLabel}</div>
  <div class="team-row${wA ? ' wr' : wB ? ' lr' : ''}">
    <span class="team-icon">${wA ? '✅' : wB ? '❌' : ''}</span>
    <span class="tname${wA ? ' w' : wB ? ' l' : ''}" id="tn-${m.id}-A"
      ${!locked && m.teamA && !isBye(m.teamA) ? `onmouseenter="onTeamHover('${(m.teamA||'').replace(/'/g,"\\'")}')" onmouseleave="onTeamLeave()"` : ''}
    >${wA || wB ? (m.teamA || '') : dispA}</span>
    <input class="score-inp" id="sca-${m.id}" type="number" min="0" value="${m.scoreA||''}" ${locked ? 'disabled' : ''}>
    <button class="pick-btn" onclick="selectWinner(${m.id},'A')" ${locked ? 'disabled' : ''}>Pick</button>
  </div>
  <div class="team-row${wB ? ' wr' : wA ? ' lr' : ''}">
    <span class="team-icon">${wB ? '✅' : wA ? '❌' : ''}</span>
    <span class="tname${wB ? ' w' : wA ? ' l' : ''}" id="tn-${m.id}-B"
      ${!locked && m.teamB && !isBye(m.teamB) ? `onmouseenter="onTeamHover('${(m.teamB||'').replace(/'/g,"\\'")}')" onmouseleave="onTeamLeave()"` : ''}
    >${wA || wB ? (m.teamB || '') : dispB}</span>
    <input class="score-inp" id="scb-${m.id}" type="number" min="0" value="${m.scoreB||''}" ${locked ? 'disabled' : ''}>
    <button class="pick-btn" onclick="selectWinner(${m.id},'B')" ${locked ? 'disabled' : ''}>Pick</button>
  </div>
  <div class="match-foot">
    <span class="lbl">Board:</span>
    <input class="board-inp" id="brd-${m.id}" type="text" value="${boardVal}" ${locked ? 'disabled' : ''} oninput="updateBoardBoxes()" placeholder="#">
    <button class="undo-btn" onclick="undoMatch(${m.id})">G ↩</button>
  </div>
</div>`;
}

function renderBracket() {
  if (!S.bracket) return;
  const { wbR, lbR, lbN, gf, K } = S.bracket;

  const wbEl = document.getElementById('wb-rounds');
  wbEl.innerHTML = '';
  for (let r = 1; r <= K; r++) {
    const col = document.createElement('div');
    col.className = 'bracket-column';
    const rMatches = wbR[r] || [];
    const header = rMatches[0]?.roundName || 'R' + r;
    col.innerHTML = `<div class="col-header">${header}</div><div class="col-matches" id="wbc-${r}"></div>`;
    wbEl.appendChild(col);
    const cm = col.querySelector('#wbc-' + r);
    rMatches.forEach(m => cm.innerHTML += matchCard(m));
  }

  const lbEl = document.getElementById('lb-rounds');
  lbEl.innerHTML = '';
  for (let r = 1; r <= lbN; r++) {
    const col = document.createElement('div');
    col.className = 'bracket-column';
    const rMatches = lbR[r] || [];
    const header = rMatches[0]?.roundName || 'LB R' + r;
    col.innerHTML = `<div class="col-header">${header}</div><div class="col-matches" id="lbc-${r}"></div>`;
    lbEl.appendChild(col);
    const cm = col.querySelector('#lbc-' + r);
    rMatches.forEach(m => cm.innerHTML += matchCard(m));
  }

  document.getElementById('gf-match').innerHTML = matchCard(gf);
}

// ============================================================
// STANDINGS
// ============================================================
function renderStandings() {
  const tbody = document.getElementById('standings-body');
  const rows = S.teams.map(t => {
    const st = S.teamStats[t.name] || { points: 0, legs: 0, avgSum: 0, played: 0, s180: 0, highOuts: [] };
    const avg = st.legs > 0 ? (st.avgSum / st.legs).toFixed(2) : '-';
    const highOut = st.highOuts && st.highOuts.length > 0 ? Math.max(...st.highOuts) : '-';
    return { name: t.name, points: st.points, avg, played: st.played, s180: st.s180, highOut };
  });
  rows.sort((a, b) => b.points - a.points || b.played - a.played);
  tbody.innerHTML = rows.map((r, i) =>
    `<tr><td>${i + 1}</td><td><span class="team-link" onclick="openStatsPopup('${r.name.replace(/'/g, "&apos;")}')">${
      r.name}</span></td><td><b>${r.points}</b></td><td>${r.avg}</td><td>${r.played}</td><td>${r.s180}</td><td>${r.highOut}</td></tr>`
  ).join('');
}

// ============================================================
// HISTORY
// ============================================================
function renderHistory() {
  const tbody = document.getElementById('history-body');
  tbody.innerHTML = S.history.map(h =>
    `<tr><td>${h.n}</td><td>${h.round}</td><td>${h.teamA}</td><td>${h.sA}</td><td>${h.sB}</td><td>${h.teamB}</td><td style="color:var(--green)">${h.winner}</td><td>${h.board || '-'}</td></tr>`
  ).join('');
}

function exportHistory() {
  if (!S.history.length) { alert('Henüz tamamlanan maç yok.'); return; }
  const headers = ['No', 'Round', 'Takım A', 'Skor A', 'Skor B', 'Takım B', 'Kazanan', 'Board NO'];
  const dataRows = S.history.map(h => [h.n, h.round, h.teamA, h.sA, h.sB, h.teamB, h.winner, h.board || '']);
  try {
    if (typeof XLSX !== 'undefined') {
      const aoa = [headers, ...dataRows];
      const ws = XLSX.utils.aoa_to_sheet(aoa);
      ws['!cols'] = [{wch:5},{wch:18},{wch:22},{wch:8},{wch:8},{wch:22},{wch:22},{wch:10}];
      const wbXlsx = XLSX.utils.book_new();
      XLSX.utils.book_append_sheet(wbXlsx, ws, 'Maç Geçmişi');
      const wbout = XLSX.write(wbXlsx, { bookType: 'xlsx', type: 'array' });
      const blob = new Blob([wbout], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a'); a.href = url; a.download = 'turnuva_gecmis.xlsx';
      document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url);
    } else { throw new Error('XLSX not loaded'); }
  } catch (e) {
    const csvRows = [headers, ...dataRows];
    const csv = csvRows.map(r => r.map(v => '"' + String(v).replace(/"/g, '""') + '"').join(',')).join('\r\n');
    const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href = url; a.download = 'turnuva_gecmis.csv';
    document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url);
  }
}

// ============================================================
// BOARD BOXES
// ============================================================
function updateBoardBoxes() {
  for (let i = 1; i <= 11; i++) {
    const box = document.getElementById('bb-' + i);
    if (!box) continue;
    const active = S.matches.some(m => {
      const bv = getBoardValue(m.id);
      return String(bv) === String(i) && !m.locked && m.teamA && m.teamB && !isBye(m.teamA) && !isBye(m.teamB);
    });
    box.classList.toggle('active', active);
  }
}

function initBoardBoxes() {
  const c = document.getElementById('board-boxes');
  c.innerHTML = '';
  for (let i = 1; i <= 11; i++) {
    c.innerHTML += `<div class="board-box" id="bb-${i}">${i}</div>`;
  }
}

// ============================================================
// OVERLAY (Active Matches)
// ============================================================
function openOverlay() {
  renderOverlay();
  document.getElementById('active-overlay').style.display = 'flex';
  renderViz('viz-svg');
}
function closeOverlay() {
  document.getElementById('active-overlay').style.display = 'none';
}

function renderOverlay() {
  const list = document.getElementById('ov-active-list');
  const active = S.matches.filter(m => !m.locked && m.teamA && m.teamB && !isBye(m.teamA) && !isBye(m.teamB));
  if (!active.length) {
    list.innerHTML = '<div class="no-active">⏳ Aktif maç bulunmuyor</div>';
    renderViz('viz-svg');
    return;
  }
  list.innerHTML = active.map(m => {
    const board = m.board || '';
    const bdg = board
      ? `<div class="board-badge">${board}</div>`
      : `<div class="board-badge board-badge-empty">-</div>`;
    const hasWinnerPick = S.vizWinner[m.id];
    const rowCls = hasWinnerPick ? 'active-row winner-selected' : 'active-row';
    return `<div class="${rowCls}" id="ovr-${m.id}">
      ${bdg}
      <div class="active-teams">
        <div class="active-teams-main">${m.teamA} <span style="color:#4a9a7a">vs</span> ${m.teamB}</div>
        <div class="active-teams-info">M${m.id} &bull; ${m.roundName}</div>
      </div>
      <div class="ov-pick-btns">
        <button class="ov-pick-btn${S.vizWinner[m.id]==='A' ? ' picked-a' : ''}" onclick="selectWinnerFromViz(${m.id},'A');event.stopPropagation()">${m.teamA.length>12?m.teamA.slice(0,11)+'…':m.teamA} ✓</button>
        <button class="ov-pick-btn${S.vizWinner[m.id]==='B' ? ' picked-b' : ''}" onclick="selectWinnerFromViz(${m.id},'B');event.stopPropagation()">${m.teamB.length>12?m.teamB.slice(0,11)+'…':m.teamB} ✓</button>
      </div>
    </div>`;
  }).join('');
  renderViz('viz-svg');
}

function highlightCard(mid) {
  closeOverlay();
  const el = document.getElementById('mc-' + mid);
  if (el) {
    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
    el.classList.add('highlighted');
    setTimeout(() => el.classList.remove('highlighted'), 3000);
  }
}

// ============================================================
// BRACKET FULL VIEW OVERLAY
// ============================================================
function openBracketOverlay() {
  document.getElementById('bracket-overlay').style.display = 'flex';
  renderViz('bov-svg');
}
function closeBracketOverlay() {
  document.getElementById('bracket-overlay').style.display = 'none';
}

// ============================================================
// BRACKET VISUALIZATION (SVG) — shared for both overlays
// ============================================================
function renderViz(svgId) {
  const svg = document.getElementById(svgId || 'viz-svg');
  if (!svg) return;
  if (!S.bracket) {
    svg.innerHTML = '<text x="20" y="40" fill="#4a7a5a" font-size="14">Turnuva başlatılmadı.</text>';
    return;
  }

  const NW = 200, NH = 78, HGAP = 34, VGAP = 18;
  const { wbR, lbR, lbN, gf, K } = S.bracket;

  const wbCols = [];
  for (let r = 1; r <= K; r++) wbCols.push(wbR[r] || []);
  const lbCols = [];
  for (let r = 1; r <= lbN; r++) lbCols.push(lbR[r] || []);

  const pos = {};
  const wbMaxRows = wbCols[0] ? wbCols[0].length : 1;
  const wbTotalH = wbMaxRows * (NH + VGAP);

  for (let ci = 0; ci < wbCols.length; ci++) {
    const col = wbCols[ci];
    const x = ci * (NW + HGAP);
    const step = wbTotalH / (col.length || 1);
    col.forEach((m, ri) => {
      const y = ri * step + (step - NH) / 2;
      pos[m.id] = { x, y, cx: x + NW / 2, cy: y + NH / 2 };
    });
  }

  const wbWidth = K * (NW + HGAP);
  const lbStartY = wbTotalH + 48;
  const lbMaxRows = lbCols[0] ? lbCols[0].length : 1;
  const lbTotalH = lbMaxRows * (NH + VGAP);

  for (let ci = 0; ci < lbCols.length; ci++) {
    const col = lbCols[ci];
    const x = ci * (NW + HGAP);
    const step = lbTotalH / (col.length || 1);
    col.forEach((m, ri) => {
      const y = lbStartY + ri * step + (step - NH) / 2;
      pos[m.id] = { x, y, cx: x + NW / 2, cy: y + NH / 2 };
    });
  }

  const gfX = Math.max(wbWidth, lbCols.length * (NW + HGAP)) + HGAP;
  const gfY = (wbTotalH + lbStartY + lbTotalH) / 2 - NH / 2;
  pos[gf.id] = { x: gfX, y: gfY, cx: gfX + NW / 2, cy: gfY + NH / 2 };

  const totalW = gfX + NW + 30;
  const totalH = lbStartY + lbTotalH + 30;

  svg.setAttribute('width', totalW);
  svg.setAttribute('height', totalH);
  svg.style.minWidth = totalW + 'px';
  svg.style.minHeight = totalH + 'px';

  let html = '';

  const allM = S.matches;

  // Draw connections
  for (const m of allM) {
    if (!pos[m.id]) continue;
    const { x, y, cx, cy } = pos[m.id];
    if (m.winTo && pos[m.winTo]) {
      const t = pos[m.winTo];
      const mx = (x + NW + t.x) / 2;
      html += `<path d="M${x+NW},${cy} C${mx},${cy} ${mx},${t.cy} ${t.x},${t.cy}" stroke="#17d766" stroke-width="3" fill="none" opacity="0.9"/>`;
    }
    if (m.loseTo && pos[m.loseTo]) {
      const t = pos[m.loseTo];
      const mx = (x + NW + t.x) / 2;
      html += `<path d="M${x+NW},${cy} C${mx+22},${cy} ${mx+22},${t.cy} ${t.x},${t.cy}" stroke="#ff3b3b" stroke-width="2.5" fill="none" stroke-dasharray="8,4" opacity="0.9"/>`;
    }
  }

  // Draw nodes
  for (const m of allM) {
    if (!pos[m.id]) continue;
    const { x, y } = pos[m.id];
    const locked = m.locked;
    const boardVal = m.board || '';
    const inProg = !locked && m.teamA && m.teamB && boardVal && !isBye(m.teamA) && !isBye(m.teamB);
    const canPick = !locked && m.teamA && m.teamB && !isBye(m.teamA) && !isBye(m.teamB);
    const isGF = m.bracket === 'GF';

    const fill = locked ? '#021a13' : (inProg ? '#0a3d28' : '#063326');
    const stroke = isGF ? '#d6a62b' : (inProg ? '#39ff14' : (canPick ? '#1a5a40' : '#0b4f40'));
    const sw = isGF ? 2.5 : (inProg ? 2.5 : 1);

    const tA = m.teamA || '?';
    const tB = m.teamB || '?';
    const wA = locked && m.winnerSlot === 'A';
    const wB = locked && m.winnerSlot === 'B';

    const colorA = wA ? '#17d766' : (locked && !wA ? '#ff3b3b' : '#e9fff7');
    const colorB = wB ? '#17d766' : (locked && !wB ? '#ff3b3b' : '#e9fff7');
    const decA = (locked && !wA) ? 'line-through' : 'none';
    const decB = (locked && !wB) ? 'line-through' : 'none';

    const truncA = tA.length > 20 ? tA.slice(0, 19) + '…' : tA;
    const truncB = tB.length > 20 ? tB.slice(0, 19) + '…' : tB;

    // Board input field on top of match box (only for bracket overlay)
    let boardInputHtml = '';
    if (svgId === 'bov-svg' && !locked) {
      boardInputHtml = `<foreignObject x="${x+NW-60}" y="${y-20}" width="60" height="20">
        <input xmlns="http://www.w3.org/1999/xhtml" type="text" placeholder="Board#"
          value="${boardVal}"
          style="width:58px;background:#072b22;color:#39ff14;border:1px solid #39ff14;border-radius:3px;font-size:10px;padding:2px 4px;font-family:Segoe UI,sans-serif;font-weight:700;text-align:center;"
          onchange="setBoardFromViz(${m.id},this.value)"
          onclick="event.stopPropagation()"
        />
      </foreignObject>`;
    }

    // Pick buttons
    let pickHtml = '';
    if (canPick) {
      const btnW = 36, btnH = 13, btnGap = 2;
      const bx = x + NW - btnW - 4;
      pickHtml += `<rect x="${bx}" y="${y + NH/2 - btnH - btnGap}" width="${btnW}" height="${btnH}" rx="4" fill="#0b4f40" stroke="#17d766" stroke-width="0.8" style="cursor:pointer" onclick="selectWinnerFromViz(${m.id},'A');event.stopPropagation()"/>`;
      pickHtml += `<text x="${bx + btnW/2}" y="${y + NH/2 - btnGap - btnH/2 + 4}" fill="#17d766" font-size="8" font-weight="700" text-anchor="middle" style="cursor:pointer" onclick="selectWinnerFromViz(${m.id},'A');event.stopPropagation()">✓ Pick</text>`;
      pickHtml += `<rect x="${bx}" y="${y + NH/2 + btnGap}" width="${btnW}" height="${btnH}" rx="4" fill="#0b4f40" stroke="#17d766" stroke-width="0.8" style="cursor:pointer" onclick="selectWinnerFromViz(${m.id},'B');event.stopPropagation()"/>`;
      pickHtml += `<text x="${bx + btnW/2}" y="${y + NH/2 + btnGap + btnH/2 + 4}" fill="#17d766" font-size="8" font-weight="700" text-anchor="middle" style="cursor:pointer" onclick="selectWinnerFromViz(${m.id},'B');event.stopPropagation()">✓ Pick</text>`;
    }

    html += `<g class="viz-node" onclick="highlightCard(${m.id})" style="cursor:pointer">
      ${boardInputHtml}
      ${inProg ? `<rect x="${x-3}" y="${y-3}" width="${NW+6}" height="${NH+6}" rx="11" ry="11" fill="none" stroke="#39ff14" stroke-width="1.5" opacity="0.4"/>` : ''}
      <rect x="${x}" y="${y}" width="${NW}" height="${NH}" rx="8" ry="8"
        fill="${fill}" stroke="${stroke}" stroke-width="${sw}"/>
      ${inProg ? `<rect x="${x}" y="${y}" width="${NW}" height="${NH}" rx="8" ry="8" fill="#39ff14" opacity="0.04"/>` : ''}
      <text x="${x+7}" y="${y+14}" fill="#d6a62b" font-size="9.5" font-weight="700">M${m.id} ${m.roundName}</text>
      <line x1="${x}" y1="${y+NH/2}" x2="${x+NW}" y2="${y+NH/2}" stroke="${inProg ? '#2a6a4a' : '#0b4f40'}" stroke-width="${inProg ? 1 : 0.5}"/>
      ${inProg && boardVal ? `<circle cx="${x+NW/2}" cy="${y+NH/2}" r="11" fill="#072b22" stroke="#39ff14" stroke-width="1.8"/><text x="${x+NW/2}" y="${y+NH/2+4}" fill="#39ff14" font-size="11" font-weight="800" text-anchor="middle">${boardVal}</text>` : ''}
      <text x="${x+7}" y="${y+NH/2-7}" fill="${colorA}" font-size="12" font-weight="600" text-decoration="${decA}">${truncA}</text>
      <text x="${canPick ? x+NW-48 : x+NW-8}" y="${y+NH/2-7}" fill="${colorA}" font-size="11" text-anchor="end">${wA ? m.scoreA : (m.scoreA||'')}</text>
      <text x="${x+7}" y="${y+NH/2+17}" fill="${colorB}" font-size="12" font-weight="600" text-decoration="${decB}">${truncB}</text>
      <text x="${canPick ? x+NW-48 : x+NW-8}" y="${y+NH/2+17}" fill="${colorB}" font-size="11" text-anchor="end">${wB ? m.scoreB : (m.scoreB||'')}</text>
      ${pickHtml}
    </g>`;
  }

  if (wbCols.length > 0) html += `<text x="4" y="14" fill="#d6a62b" font-size="13" font-weight="700">WINNERS BRACKET</text>`;
  if (lbCols.length > 0) html += `<text x="4" y="${lbStartY - 10}" fill="#d6a62b" font-size="13" font-weight="700">LOSERS BRACKET</text>`;

  svg.innerHTML = html;
}

// Set board number from bracket overlay SVG input
function setBoardFromViz(mid, val) {
  const m = getM(mid);
  if (!m || m.locked) return;
  m.board = val.trim();
  // Sync to main bracket DOM input if visible
  const bEl = document.getElementById('brd-' + mid);
  if (bEl) bEl.value = m.board;
  updateBoardBoxes();
}

// ============================================================
// STATS POPUP
// ============================================================
function openStatsPopup(name) {
  S.statsTeam = name;
  const st = S.teamStats[name] || {};
  document.getElementById('sp-title').textContent = name + ' - İstatistikler';
  document.getElementById('sp-180').value = st.s180 || 0;
  document.getElementById('sp-out').value = (st.outNums || []).join(',');
  document.getElementById('sp-hout').value = (st.highOuts || []).join(',');
  document.getElementById('popup-bg').style.display = 'block';
  document.getElementById('stats-popup').style.display = 'block';
}
function closeStatsPopup() {
  document.getElementById('popup-bg').style.display = 'none';
  document.getElementById('stats-popup').style.display = 'none';
  S.statsTeam = null;
}
function saveStatsPopup() {
  if (!S.statsTeam) return;
  const ensure = n => {
    if (!S.teamStats[n]) S.teamStats[n] = { points:0,legs:0,avgSum:0,played:0,s180:0,highOuts:[],outNums:[],wbWins:0,lbWins:0,gfWin:false };
  };
  ensure(S.statsTeam);
  S.teamStats[S.statsTeam].s180 = parseInt(document.getElementById('sp-180').value) || 0;
  const hv = document.getElementById('sp-hout').value;
  S.teamStats[S.statsTeam].highOuts = hv ? hv.split(',').map(v => parseInt(v.trim())).filter(v => !isNaN(v)) : [];
  const ov = document.getElementById('sp-out').value;
  S.teamStats[S.statsTeam].outNums = ov ? ov.split(',').map(v => parseInt(v.trim())).filter(v => !isNaN(v)) : [];
  closeStatsPopup();
  renderStandings();
}

// ============================================================
// INIT
// ============================================================
function init() {
  const sel = document.getElementById('team-count-select');
  for (let i = 6; i <= 50; i++) {
    if (i % 2 !== 0 && i !== 6) continue; // only even + 6
    // allow all even numbers 6-50
    const opt = document.createElement('option');
    opt.value = i; opt.textContent = i + ' takım';
    if (i === 16) opt.selected = true;
    sel.appendChild(opt);
  }

  // Set today's date
  const today = new Date();
  document.getElementById('tournament-date').value = today.toISOString().slice(0, 10);

  initBoardBoxes();

  // Demo 16 teams
  const demoNames = [
    'Team Alpha','Team Beta','Team Gamma','Team Delta',
    'Team Epsilon','Team Zeta','Team Eta','Team Theta',
    'Team Iota','Team Kappa','Team Lambda','Team Mu',
    'Team Nu','Team Xi','Team Omicron','Team Pi'
  ];
  document.getElementById('team-names').value = demoNames.join('\n');
  applyTournament();
}

// Run on load
window.addEventListener('DOMContentLoaded', init);
</script>
</body>
</html>
